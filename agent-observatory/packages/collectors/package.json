{
  "name": "@agent-observatory/collectors",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./claude-code/parser": {
      "types": "./dist/claude-code/parser.d.ts",
      "default": "./dist/claude-code/parser.js"
    },
    "./claude-code/normalizer": {
      "types": "./dist/claude-code/normalizer.d.ts",
      "default": "./dist/claude-code/normalizer.js"
    },
    "./openclaw/parser": {
      "types": "./dist/openclaw/parser.d.ts",
      "default": "./dist/openclaw/parser.js"
    },
    "./openclaw/normalizer": {
      "types": "./dist/openclaw/normalizer.d.ts",
      "default": "./dist/openclaw/normalizer.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@agent-observatory/shared": "file:../shared",
    "better-sqlite3": "^12.6.2",
    "chokidar": "^4.0.0",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
